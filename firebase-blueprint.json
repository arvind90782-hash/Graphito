{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Project details and tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "review", "completed", "cancelled"] },
        "clientUid": { "type": "string" },
        "budget": { "type": "string" },
        "deadline": { "type": "string" },
        "driveLinks": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "clientUid", "status"]
    },
    "ProjectFile": {
      "title": "ProjectFile",
      "description": "Files uploaded for a project",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "url", "uploadedBy"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat messages between agency and client",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderUid", "content", "timestamp"]
    },
    "PortfolioItem": {
      "title": "PortfolioItem",
      "description": "Work showcase items",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["title", "category"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "projectType": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "projectType"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main project documents"
    },
    "/projects/{projectId}/files/{fileId}": {
      "schema": "ProjectFile",
      "description": "Files associated with a project"
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Project-specific chat messages"
    },
    "/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Portfolio showcase"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Contact form leads"
    }
  }
}
