rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role (admin/client), createdAt
    //
    // Collection: projects
    // Fields: id, title, description, status, clientUid, budget, deadline, driveLinks, createdAt, updatedAt
    //
    // Collection: portfolio
    // Fields: title, category, imageUrl, videoUrl, description
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "arvind90782@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "contact@graphitoagency.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'client'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'clientUid', 'status']) &&
             data.title is string && data.title.size() < 200 &&
             data.clientUid is string &&
             data.status in ['pending', 'in-progress', 'review', 'completed', 'cancelled'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'projectType', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             isValidEmail(data.email) &&
             data.projectType is string &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'client' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) &&
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.clientUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidProject(request.resource.data) &&
                    (request.resource.data.clientUid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidProject(request.resource.data) &&
                    (resource.data.clientUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /files/{fileId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/projects/$(projectId)).data.clientUid == request.auth.uid || isAdmin());
        allow write: if isAuthenticated() && (get(/databases/$(database)/documents/projects/$(projectId)).data.clientUid == request.auth.uid || isAdmin());
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/projects/$(projectId)).data.clientUid == request.auth.uid || isAdmin());
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/projects/$(projectId)).data.clientUid == request.auth.uid || isAdmin());
      }
    }

    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if isValidLead(request.resource.data);
    }
  }
}
